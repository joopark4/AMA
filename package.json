{
  "name": "mypartnerai",
  "version": "1.5.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare:assets": "node scripts/prepare-assets.mjs",
    "motion:validate": "node scripts/validate-motion-assets.mjs",
    "dev": "npm run clean:dotfiles && PREPARE_PUBLIC_MODELS=1 PREPARE_BUNDLE_RESOURCES=0 npm run prepare:assets && vite",
    "build": "npm run clean:dotfiles && PREPARE_PUBLIC_MODELS=0 PREPARE_BUNDLE_RESOURCES=1 npm run prepare:assets && tsc && vite build",
    "preview": "vite preview",
    "clean:dotfiles": "find . -name '._*' -not -path './.git/*' -not -path './node_modules/*' -not -path './.build/*' -delete",
    "tauri": "COPYFILE_DISABLE=1 CARGO_TARGET_DIR=$HOME/Library/Caches/mypartnerai-build tauri",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^0.7.0",
    "@huggingface/transformers": "^3.8.1",
    "@pixiv/three-vrm": "^3.4.0",
    "@react-three/drei": "^9.117.0",
    "@react-three/fiber": "^8.17.10",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.5.0",
    "i18next": "^24.2.0",
    "onnxruntime-web": "^1.17.3",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "three": "^0.170.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "onnxruntime-node": "^1.23.2",
    "postcss": "^8.4.49",
    "puppeteer": "^24.36.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
