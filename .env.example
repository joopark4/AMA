# MyPartnerAI Environment Configuration

# Supabase Auth (Project Settings → API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Cloud LLM API keys are NOT loaded from env.
# Users enter their own keys via the in-app Settings UI (BYO Key pattern).
# (Legacy fields removed: VITE_ANTHROPIC_API_KEY, VITE_OPENAI_API_KEY, VITE_GOOGLE_API_KEY)

# Local LLM Configuration
VITE_OLLAMA_ENDPOINT=http://localhost:11434
VITE_LOCALAI_ENDPOINT=http://localhost:8080

# Default Settings
VITE_DEFAULT_LLM_PROVIDER=ollama
VITE_DEFAULT_LLM_MODEL=deepseek-v3
VITE_DEFAULT_STT_ENGINE=whisper
VITE_DEFAULT_TTS_ENGINE=kokoro
VITE_DEFAULT_LANGUAGE=ko
