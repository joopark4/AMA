{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "AMA",
  "version": "1.9.8",
  "identifier": "com.mypartnerai",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AMA",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: https://ipc.localhost asset: https://asset.localhost; connect-src 'self' blob: data: tauri: ipc: https://ipc.localhost asset: https://asset.localhost https://*.supabase.co wss://*.supabase.co https://api.anthropic.com https://api.openai.com https://generativelanguage.googleapis.com https://huggingface.co https://*.huggingface.co https://api.supertone.ai http://localhost:* ws://localhost:*; script-src 'self' 'wasm-unsafe-eval' tauri:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: asset: https://asset.localhost; font-src 'self' data:; media-src 'self' data: blob: asset: https://asset.localhost; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/bin/": "bin/",
      "resources/lib/": "lib/",
      "resources/ama-bridge/": "ama-bridge/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "hardenedRuntime": true,
      "infoPlist": "./Info.plist",
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 420
        },
        "appPosition": {
          "x": 200,
          "y": 180
        },
        "applicationFolderPosition": {
          "x": 520,
          "y": 180
        }
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": [
        {
          "schemes": [
            "ama"
          ]
        }
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/joopark4/AMA/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4NkY5NUEwNTAyRTc3QTQKUldTa2R5NVFvSlZ2ZUlCclFyM0FRbFY4NmtDSGY1SmxsR1U2MXYvUFVac2drbUxEVENSN3pFdVEK",
      "dialog": false
    }
  }
}
