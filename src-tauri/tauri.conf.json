{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "AMA",
  "version": "1.5.0",
  "identifier": "com.mypartnerai",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AMA",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/bin/": "bin/",
      "resources/lib/": "lib/",
      "resources/ama-bridge/": "ama-bridge/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "Developer ID Application: byeong joo kim (R5N5JUB2P2)",
      "hardenedRuntime": true,
      "infoPlist": "./Info.plist",
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 420
        },
        "appPosition": {
          "x": 200,
          "y": 180
        },
        "applicationFolderPosition": {
          "x": 520,
          "y": 180
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/joopark4/AMA/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2Q0I4QkIxQ0VENzAwQTkKUldTcEFOZk9zWXZMTnFNOWxXUUtuNThqTVRoSDRrcGhQS250QWdUaUcvR1pZZ05paU5oOGJuM0UK",
      "dialog": false
    }
  }
}
