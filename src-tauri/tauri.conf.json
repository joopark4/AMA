{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "MyPartnerAI",
  "version": "0.1.1",
  "identifier": "com.mypartnerai",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MyPartnerAI",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "resources": {
      "resources/models/": "models/",
      "resources/bin/": "bin/",
      "resources/lib/": "lib/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "hardenedRuntime": true,
      "infoPlist": "./Info.plist",
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 420
        },
        "appPosition": {
          "x": 200,
          "y": 180
        },
        "applicationFolderPosition": {
          "x": 520,
          "y": 180
        }
      }
    }
  },
  "plugins": {}
}
